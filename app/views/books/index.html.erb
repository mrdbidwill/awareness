<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Books & References</h1>

  <% if @books.any? %>
    <div class="space-y-4">
      <% @books.each do |book| %>
        <div class="bg-white shadow rounded-lg p-6">
          <h2 class="text-xl font-semibold mb-2"><%= book[:title] %></h2>
          <p class="text-gray-600 mb-1"><strong>Author:</strong> <%= book[:author] %></p>
          <p class="text-sm text-gray-500 mb-2"><strong>Type:</strong> <%= book[:format] %></p>
          <% if book[:notes].present? %>
            <p class="text-gray-700"><%= book[:notes] %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-600">Book recommendations will be added soon.</p>
  <% end %>
</div>
