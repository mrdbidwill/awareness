<% content_for :title, "Newsletter Signup" %>

<div class="max-w-2xl rounded-lg border border-emerald-200 bg-white p-6">
  <h1 class="text-2xl font-bold text-gray-900">Newsletter Signup</h1>
  <p class="mt-2 text-sm text-gray-700">
    Get new mycology articles by email. We use double opt-in, so you will receive a confirmation link first.
  </p>

  <%= render "shared/newsletter_signup_form", subscriber: @subscriber %>

  <p class="mt-4 text-xs text-gray-500">
    You can unsubscribe at any time from any newsletter email.
  </p>
</div>
