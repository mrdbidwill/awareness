<% content_for :title, "Admin · #{@source.name}" %>

<div class="w-full max-w-4xl">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <h1 class="text-2xl font-bold"><%= @source.name %></h1>
    <div class="flex gap-2">
      <%= link_to "Back to Sources", admin_sources_path, class: "rounded border border-gray-300 px-3 py-2 hover:bg-gray-50" %>
      <%= link_to "Edit", edit_admin_source_path(@source), class: "rounded bg-blue-600 px-3 py-2 text-white hover:bg-blue-700" %>
      <%= button_to "Delete", admin_source_path(@source), method: :delete, class: "rounded bg-red-600 px-3 py-2 text-white hover:bg-red-700", data: { turbo_confirm: "Delete this source?" } %>
    </div>
  </div>

  <div class="rounded border bg-white p-4">
    <p class="text-sm text-gray-600">
      <strong>Author:</strong> <%= @source.author.presence || "Unknown" %>
    </p>
    <p class="mt-1 text-sm text-gray-600">
      <strong>Publish Year:</strong> <%= @source.publish_date&.year || "Not set" %>
    </p>
    <div class="mt-4 whitespace-pre-wrap text-gray-800">
      <%= @source.description.presence || "No description provided." %>
    </div>
  </div>
</div>
