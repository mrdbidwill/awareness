<%= form_with(model: [:admin, @source], class: "space-y-4") do |f| %>
  <% if @source.errors.any? %>
    <div class="rounded border border-red-300 bg-red-50 p-3 text-sm text-red-700">
      <p class="font-semibold"><%= pluralize(@source.errors.count, "error") %> prevented saving:</p>
      <ul class="mt-2 list-disc pl-5">
        <% @source.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-semibold text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :author, class: "block text-sm font-semibold text-gray-700" %>
    <%= f.text_area :author, rows: 3, class: "mt-1 w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :publish_year, "Publish Year", class: "block text-sm font-semibold text-gray-700" %>
    <%= f.number_field :publish_year, min: 1000, max: 9999, step: 1, placeholder: "YYYY", class: "mt-1 w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-semibold text-gray-700" %>
    <%= f.text_area :description, rows: 6, class: "mt-1 w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <%= render "admin/shared/form_actions",
             record: @source,
             back_path: admin_sources_path,
             submit_text: (@source.persisted? ? "Update Source" : "Create Source"),
             back_text: "Back to Sources" %>
<% end %>
