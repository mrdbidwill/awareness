<h1 class="bg-gray-100 text-red-800 mx-auto px-2 py-1 text-4xl text-center">Awareness Admin Dashboard</h1>
<p class="text-center text-red-800 mb-6">
  Manage editorial content and site operations for Awareness.
</p>

<div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-gray-500">Users</p>
    <p class="text-2xl font-bold text-gray-900"><%= @users_count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-gray-500">Published Articles</p>
    <p class="text-2xl font-bold text-gray-900"><%= @published_articles_count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-gray-500">Newsletter Subscribers</p>
    <p class="text-2xl font-bold text-gray-900"><%= @newsletter_subscribers_count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-gray-500">Subjects</p>
    <p class="text-2xl font-bold text-gray-900"><%= @subjects_count %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-gray-500">References</p>
    <p class="text-2xl font-bold text-gray-900"><%= @references_count %></p>
  </div>
</div>

<nav class="admin-dashboard-nav">
  <ul class="space-y-3 ml-6">
    <li class="flex items-start">
      <span class="text-blue-600 mr-2 flex-shrink-0">▸</span>
      <%= link_to "Users", admin_users_path, class: "text-blue-600 hover:text-blue-800 hover:underline font-medium" %>
    </li>
    <li class="flex items-start">
      <span class="text-blue-600 mr-2 flex-shrink-0">▸</span>
      <%= link_to "Articles", admin_articles_path, class: "text-blue-600 hover:text-blue-800 hover:underline font-medium" %>
    </li>
    <li class="flex items-start">
      <span class="text-blue-600 mr-2 flex-shrink-0">▸</span>
      <span>
        <%= link_to "Newsletter Campaigns", admin_newsletter_campaigns_path, class: "text-blue-600 hover:text-blue-800 hover:underline font-medium" %>
        Send group emails to confirmed subscribers via background jobs.
      </span>
    </li>
    <li class="flex items-start">
      <span class="text-blue-600 mr-2 flex-shrink-0">▸</span>
      <%= link_to "References", admin_references_path, class: "text-blue-600 hover:text-blue-800 hover:underline font-medium" %>
    </li>
    <li class="flex items-start">
      <span class="text-blue-600 mr-2 flex-shrink-0">▸</span>
      <%= link_to "Subjects", admin_subjects_path, class: "text-blue-600 hover:text-blue-800 hover:underline font-medium" %>
    </li>
  </ul>
</nav>
