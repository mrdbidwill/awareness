<nav class="bg-gray-100 text-gray-800 w-full px-4 md:px-6 py-3 md:py-4">
  <div class="w-full flex flex-col gap-3">
    <!-- Logo -->
    <div class="text-2xl font-bold w-full">
     <%= render "shared/logo" %>
    </div>

    <!-- Navigation Links -->
    <ul class="flex flex-wrap items-center gap-2 md:gap-2 text-sm">
      <!-- Home -->
      <% unless current_page?(root_path) %>
        <li>
          <%= link_to "Home", root_path, class: "btn-nav bg-white text-black ring-2 ring-green-400 hover:bg-green-200 hover:ring-green-700 focus:outline-none focus:ring-4" %>
        </li>
      <% end %>

      <!-- Contact -->
      <% unless current_page?(contact_path) %>
        <li>
          <%= link_to "Contact", contact_path, class: "btn-nav bg-green-600 text-white ring-2 ring-green-400 hover:bg-green-700 hover:ring-green-700 focus:outline-none focus:ring-4" %>
        </li>
      <% end %>

      <!-- Articles -->
      <% unless current_page?(articles_path) %>
        <li>
          <%= link_to "Articles", articles_path, class: "btn-nav bg-blue-600 text-white ring-2 ring-blue-300 hover:bg-blue-500 hover:ring-blue-600 focus:outline-none focus:ring-4" %>
        </li>
      <% end %>

      <!-- Newsletter -->
      <% unless current_page?(new_newsletter_path) %>
        <li>
          <%= link_to "Newsletter", new_newsletter_path, class: "btn-nav bg-blue-600 text-white ring-2 ring-blue-300 hover:bg-blue-500 hover:ring-blue-600 focus:outline-none focus:ring-4" %>
        </li>
      <% end %>

      <% if user_signed_in? %>

        <!-- Admin -->
        <% if current_user&.admin? %>
          <li>
          <%= link_to "Admin", admin_root_path, class: "btn-nav bg-red-600 text-white ring-2 ring-red-400 hover:bg-red-700 hover:ring-red-700 focus:outline-none focus:ring-4" %>
          </li>
          <% if controller_path == "admin/dashboard" %>
            <li>
              <%= link_to "References", admin_references_path, class: "btn-nav bg-blue-600 text-white ring-2 ring-blue-300 hover:bg-blue-500 hover:ring-blue-600 focus:outline-none focus:ring-4" %>
            </li>
          <% end %>

        <% end %>

        <!-- Account -->
        <% unless current_page?(edit_user_registration_path) %>
        <li>
          <%= link_to 'Account', edit_user_registration_path, class: "btn-nav bg-orange-600 text-white ring-2 ring-orange-400 hover:bg-orange-700 hover:ring-orange-700 focus:outline-none focus:ring-4" %>
        </li>
          <% end %>

        <!-- Logout -->
        <li>
          <%= button_to "Logout", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "btn-nav bg-yellow-600 text-white ring-2 ring-yellow-400 hover:bg-yellow-700 hover:ring-yellow-700 focus:outline-none focus:ring-4" %>
        </li>
      <% else %>
        <!-- Login -->
        <% unless current_page?(new_user_session_path) %>
          <li>
            <%= link_to "Log In", new_user_session_path, class: "btn-nav bg-white text-gray-800 hover:bg-gray-100 focus:outline-none focus:ring-4" %>
          </li>
        <% end %>

        <!-- Sign Up -->
        <% unless current_page?(new_user_registration_path) %>
          <li>
            <%= link_to "Sign Up", new_user_registration_path, class: "btn-nav bg-white text-gray-800 hover:bg-gray-100 focus:outline-none focus:ring-4" %>
          </li>
        <% end %>
    <% end %>
    </ul>
  </div>
</nav>
