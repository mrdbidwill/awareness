<!-- Mobile hamburger button -->
<button id="sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 p-2 bg-gray-800 text-white rounded-md shadow-lg">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>

<!-- Sidebar overlay for mobile -->
<div id="sidebar-overlay" class="lg:hidden hidden fixed inset-0 bg-black bg-opacity-50 z-30"></div>

<!-- Sidebar -->
<aside id="sidebar" class="w-64 flex-shrink-0 bg-gray-50 border-r border-gray-300 p-4 fixed lg:static h-full overflow-y-auto z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-300">
  <!-- Close button for mobile -->
  <button id="sidebar-close" class="lg:hidden absolute top-4 right-4 text-gray-600 hover:text-gray-900">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Logo/Title - Clickable -->
  <div class="mb-4 mt-8 lg:mt-0">
    <%= link_to root_path, class: "block hover:opacity-80 transition" do %>
      <%= image_tag "awareness_logo.svg",
                    alt: "Awareness — Mycology Articles",
                    class: "block h-10 w-auto select-none mb-2",
                    draggable: false %>
      <p class="text-xs text-gray-600">Awareness Mycology Articles</p>
    <% end %>
  </div>

  <!-- Logged in user info -->
  <% if user_signed_in? %>
    <div class="mb-3 p-2 bg-green-50 border border-green-300 rounded text-center">
      <p class="text-xs text-green-700 mb-1">Logged in as</p>
      <p class="text-sm font-semibold text-green-900"><%= current_user.display_name %></p>
    </div>
  <% end %>

  <!-- Home Button -->
  <div class="mb-6">
    <%= link_to "Home", root_path, class: "block px-3 py-2 rounded bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition text-center" %>
  </div>

  <!-- Context-aware section for the current mushroom -->
  <% if defined?(@mushroom) && @mushroom.present? && @mushroom.persisted? %>
    <div class="mb-4 p-3 bg-blue-50 lg:bg-blue-100 border border-blue-300 rounded">
      <div class="text-xs font-semibold text-blue-900 mb-2">Current Mushroom:</div>
      <div class="text-sm font-medium text-blue-800 mb-3"><%= @mushroom.name || "Unnamed" %></div>

      <div class="space-y-1">
        <% if current_page?(controller: 'mushrooms', action: 'show', id: @mushroom.id) %>
          <%= link_to "Edit Mushroom", edit_mushroom_path(@mushroom), class: "block px-2 py-1.5 text-xs rounded bg-green-600 hover:bg-green-700 text-white font-medium transition text-center" %>
        <% elsif current_page?(controller: 'mushrooms', action: 'edit', id: @mushroom.id) %>
          <%= link_to "View Mushroom", mushroom_path(@mushroom), class: "block px-2 py-1.5 text-xs rounded bg-blue-600 hover:bg-blue-700 text-white font-medium transition text-center" %>
        <% end %>

        <%= link_to "Upload Image", new_mushroom_image_mushroom_path(@mushroom), class: "block px-2 py-1.5 text-xs rounded bg-sky-600 hover:bg-sky-700 text-white font-medium transition text-center" %>
        <%= link_to "Compare", mushroom_mushroom_comparisons_path(mushroom_id: @mushroom.id), class: "block px-2 py-1.5 text-xs rounded bg-purple-600 hover:bg-purple-700 text-white font-medium transition text-center" %>

        <% if user_signed_in? && @mushroom.user_id == current_user.id %>
          <%= button_to "Delete Mushroom", mushroom_path(@mushroom), method: :delete,
              class: "w-full px-2 py-1.5 text-xs rounded bg-red-600 hover:bg-red-700 text-white font-medium transition text-center",
              data: { turbo_confirm: "Are you sure you want to delete this mushroom?" } %>
        <% end %>
      </div>
    </div>

    <hr class="my-4 border-gray-300">
  <% end %>

  <!-- Navigation Links -->
  <nav class="space-y-1">
    <% if user_signed_in? %>
      <%= link_to "Articles", articles_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Newsletter", new_newsletter_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Books", books_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Contact", contact_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Terms of Service", terms_path, class: "block px-3 py-2 rounded bg-gray-600 hover:bg-gray-700 text-white text-sm font-medium transition" %>

      <div class="my-2 border-t border-gray-400"></div>

      <% if current_user&.admin? %>
        <%= link_to "Admin Dashboard", admin_root_path, class: "block px-3 py-2 rounded bg-red-600 hover:bg-red-700 text-white text-sm font-medium transition" %>
        <div class="my-2 border-t border-gray-400"></div>
      <% end %>

      <%= link_to "Account", edit_user_registration_path, class: "block px-3 py-2 rounded bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium transition" %>
      <%= button_to "Logout", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "w-full text-left px-3 py-2 rounded bg-yellow-600 hover:bg-yellow-700 text-white text-sm font-medium transition" %>
    <% else %>
      <%= link_to "Articles", articles_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Newsletter", new_newsletter_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Books", books_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Contact", contact_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Terms of Service", terms_path, class: "block px-3 py-2 rounded bg-gray-600 hover:bg-gray-700 text-white text-sm font-medium transition" %>
      <%= link_to "Sign In", new_user_session_path, class: "block px-3 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition" %>
      <%= link_to "Create Account", new_user_registration_path, class: "block px-3 py-2 rounded bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition" %>
    <% end %>
  </nav>
</aside>

<!-- JavaScript for sidebar toggle -->
<script>
  function initializeSidebar() {
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarClose = document.getElementById('sidebar-close');
    const sidebarOverlay = document.getElementById('sidebar-overlay');

    if (!sidebar || !sidebarToggle || !sidebarClose || !sidebarOverlay) {
      return;
    }

    function openSidebar() {
      sidebar.classList.remove('-translate-x-full');
      sidebarOverlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      sidebar.classList.add('-translate-x-full');
      sidebarOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    sidebarToggle.replaceWith(sidebarToggle.cloneNode(true));
    sidebarClose.replaceWith(sidebarClose.cloneNode(true));
    sidebarOverlay.replaceWith(sidebarOverlay.cloneNode(true));

    const newSidebarToggle = document.getElementById('sidebar-toggle');
    const newSidebarClose = document.getElementById('sidebar-close');
    const newSidebarOverlay = document.getElementById('sidebar-overlay');

    newSidebarToggle.addEventListener('click', openSidebar);
    newSidebarClose.addEventListener('click', closeSidebar);
    newSidebarOverlay.addEventListener('click', closeSidebar);

    const sidebarLinks = sidebar.querySelectorAll('a, button[type="submit"]');
    sidebarLinks.forEach(function(link) {
      link.addEventListener('click', function() {
        if (window.innerWidth < 1024) {
          closeSidebar();
        }
      });
    });

    closeSidebar();
  }

  document.addEventListener('DOMContentLoaded', initializeSidebar);
  document.addEventListener('turbo:load', initializeSidebar);

  document.addEventListener('turbo:before-cache', function() {
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebar-overlay');

    if (sidebar && sidebarOverlay) {
      sidebar.classList.add('-translate-x-full');
      sidebarOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });
</script>
